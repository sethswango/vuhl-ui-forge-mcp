{
  "name": "vuhl-ui-forge",
  "version": "0.1.0",
  "description": "VuhluiForge MCP - context-aware screenshot-to-code generation for IDE workflows and Angular-aware integration.",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "vuhl": "./dist/server/index.js",
    "vuhl-ui-forge": "./dist/server/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:ui && npm run build:server",
    "build:ui": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:ui\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "vite build --watch",
    "start": "node dist/server/index.js",
    "start:http": "node dist/server/index.js --http",
    "start:stdio": "node dist/server/index.js --stdio",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sethswango/vuhl-ui-forge-mcp.git"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/ext-apps": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@webcontainer/api": "^1.6.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "vuhl",
    "ui-forge",
    "mcp",
    "model-context-protocol",
    "angular",
    "html",
    "tailwind",
    "design-to-code",
    "screenshot-to-code",
    "ai",
    "code-generation",
    "cursor",
    "claude"
  ],
  "author": "Seth Swango",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
